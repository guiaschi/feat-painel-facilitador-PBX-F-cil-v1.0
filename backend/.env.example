# Backend Environment Variables
# Copy this file to .env and fill in your values

PORT=5000
JWT_SECRET=your_secret_key_here_change_me_in_production

# ARI (Asterisk REST Interface) — required for the Dialer feature
ARI_URL=https://INSTANCIA.pbxfacil.com.br:2087
ARI_USER=seu_usuario_ari
ARI_PASS=sua_senha_ari
ARI_HOST=INSTANCIA.pbxfacil.com.br
ARI_PORT=2087

# For debug/test scripts (used only by inspect-*.js and test-*.js):
PBX_INSTANCE=minhainstancia
PBX_USER=admin
PBX_PASS=sua_senha

# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true # optional if Chromium already installed globally
